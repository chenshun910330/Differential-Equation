%%第一部分第一小節
\subsection{論文摘要}
%第一頁
\begin{frame}{論文摘要}
    這篇文章將\textbf{跨網絡外部性參數}引入到傳統的\textbf{Lotka-Volterra模型}中，從\textbf{雙邊市場平台競爭}的角度，研究\textbf{跨網絡外部性和跨平台抑制}對平台競爭均衡市場結構的影響。最後，使用改進的Lotka–Volterra模型實證分析在線外賣平台之間的關係。顯然，他們的研究與雙邊市場網絡外部性、Lotka-Volterra模型等領域的一些研究密切相關。

\end{frame}


%%第一部分第二小節
\subsection{名詞解釋}

%第二頁
\begin{frame}{名詞解釋}
    \begin{exampleblock}  %灰綠格子 
		<1->{內部增長率(Internal Growth Rate)}
  %標題與格子出現順序編碼
  %放大會放不下
  {\linespread{1}\small
    \selectfont
		指一家公司在不融資的情況下，能夠實現的最大營收增長率，通常用來評估一家公司的經營能力和發展潛力，需要考慮以下幾個因素：}
  {\linespread{1}\small
    \selectfont
        \textbf{\begin{itemize}
            \item  淨利潤率,Portfolio Margin  (pm)
            \item  資產報酬率,Asset Return  (r)
            \item  股東權益比率,Debt to Equity Ratio  (D/E)
        \end{itemize}}}
    {\linespread{1}\small
    \selectfont
        將內部成長率以i表示，可以將公式整理如下：}
        {\linespread{1}\small
    \selectfont
        \begin{equation}
                i = \frac{pm*r*(D/E)} {1-(pm*r*(D/E))}
        \end{equation}}
	\end{exampleblock}

\end{frame}
%第三頁
\begin{frame}{名詞解釋}
    \begin{exampleblock}  %灰綠格子 
		<1->{雙邊市場(Two-Sided Market)}
  %標題與格子出現順序編碼
  {\linespread{1}\small
    \selectfont
		指一種交易平台，該平台通常涉及\textbf{兩個不同的用戶群體}：提供商品或服務的一方和使用者或消費者的另一方。這些平台的成功往往取決於這兩個不同用戶群體之間的\textbf{網絡效應}。在雙邊市場中，\textbf{增加任何一方的參與者，都有可能增加另一方的參與者。}}
	\end{exampleblock}
\end{frame}
%第四頁
\begin{frame}{名詞解釋}
    \begin{exampleblock}  %灰綠格子 
		<1->{網路外部性(Network Externality)}
  %  https://en.wikipedia.org/wiki/Network_effect
  %標題與格子出現順序編碼
  {\linespread{1}\small
    \selectfont
		消費者選用某項商品或服務，所獲得的\textbf{效用}與「使用該商品或服務的\textbf{其他使用者人數}」\textbf{具有相關性}時，此商品或服務即被稱為具有網路外部性。}
	\end{exampleblock}
    \begin{exampleblock}  %灰綠格子 
		<2->{跨網路外部性(Cross-Network Externality)}
  {\linespread{1}\small
    \selectfont
		是\textbf{間接的網路外部性}，當「至少有兩個\textbf{相依}的不同客戶群體，並且至少一個群體的效用\textbf{隨著其他群體的增長而增長時}」會出現跨網路外部性。}
	\end{exampleblock}
\end{frame}





%%%%%%%%%%%%%%%%第二部分
\section{模型介紹}


%%第二部分第一小節
\subsection{Lotka–Volterra model}
%第五頁
\begin{frame}{Lotka–Volterra model}
	\begin{exampleblock}
	    <1->{Assumptions}
     {\linespread{1}\footnotesize
    \selectfont
        假設一個生態系統中\textbf{只有兩類物種}，它們依賴\textbf{相同的食物}生存，並且兩類物種的規模增長遵循\textbf{logistic growth}。考慮兩物種\textbf{規模變化比率}和\textbf{種群之間的相互作用}可以建立經典的Lotka - Volterra模型。}
	\end{exampleblock}
		
\end{frame}

%第六頁
\begin{frame}{Lotka–Volterra model}
    \begin{block}
		<1->{Model}
    {\linespread{0.5}\footnotesize
    \selectfont
		\begin{align}  %加註編號用
        \left\{  %加括號用
        \begin{aligned}
            \frac{dx(t)}{dt} & = & \mu_1(1-\frac{x(t)}{K_1}+\alpha\frac{y(t)}{K_2})
        \\
            \frac{dy(t)}{dt} & = & \mu_2(1-\frac{y(t)}{K_2}+\beta\frac{x(t)}{K_1})
        \end{aligned}
        \right.
        \end{align}}
	\end{block}	
    \begin{exampleblock}
	    <2->{模型解釋}
     {\footnotesize\selectfont
        在這個模型中，我們可以用：
        \begin{itemize}
            \item $\frac{x(t)}{K_1}$和$\frac{y(t)}{K_2}$考慮該環境下生物容納數量上限的對物種數量變化率的影響
            \item $\alpha\frac{y(t)}{K_2}$和$\beta\frac{x(t)}{K_1}$考慮物種之間的交互作用。
        \end{itemize}}
	\end{exampleblock}	
\end{frame}


%第七頁
\begin{frame}{模型之間的取捨}
\framesubtitle{Lotka–Volterra model與效用極大化模型的特徵}
    \begin{exampleblock}
	    <1->{Lotka–Volterra model}
     {\linespread{1}\footnotesize
    \selectfont
        主要從競爭關係的角度描述了\textbf{人口演化的長期過程}。透過該模型，我們可以揭示企業在市場競爭中的均衡狀態及其影響因素。}
    \end{exampleblock}
    \begin{exampleblock}
	    <1->{效用極大化模型}
     {\linespread{1}\footnotesize
    \selectfont
        常用於雙邊市場理論中，從\textbf{用戶最大化和平台利潤最大化}的角度研究平台公司的\textbf{競爭行為}，如定價策略。}
    \end{exampleblock}
\end{frame}

%第八頁
\begin{frame}{模型之間的取捨}
\framesubtitle{Lotka–Volterra model與效用極大化模型之間的比較}
    \begin{itemize}
        \item \textcolor{teal}{\textbf{長期與短期：}}
        \\\small\selectfont{Lotka-Volterra模型更側重於刻畫\textbf{長期}的演化特徵。用戶規模的長期增長，已經體現了平台的成本和收益。\textbf{只有當長期收益超過成本時，平台才能繼續運營。}然而，利潤最大化目標反映了一個\textbf{短期}優化問題。}
        \item \textcolor{teal}{\textbf{生存問題與最佳化問題：}}
        \\\small\selectfont{利潤最大化模型解決了一個\textbf{最佳化問題}，而Lotka–Volterra模型解決了一個\textbf{生存問題}。對於平台競爭等複雜系統，更適合用\textbf{生存}的視角來分析此類問題。}
    \end{itemize}
\end{frame}


%%第二部分第二小節
\subsection{建立雙平台及三平台競爭模型}

%第九頁
\begin{frame}{雙平台競爭模型}
\framesubtitle{Duopoly competition model of bilateral platform}
以兩物種競爭類比平台間的雙寡頭競爭時，因為是雙邊市場，所以模型會變得更為複雜，我們先簡單地以圖示呈現一部份變數之間的關聯：
    \\
    \begin{figure}[h]
    \centering
    \includegraphics[width=8cm]{photo.png}
    \caption{雙平台模型變數圖說}
    \end{figure}
\end{frame}

%第十頁
\begin{frame}{雙平台競爭模型}
\framesubtitle{Duopoly competition model of bilateral platform}
    \begin{exampleblock}
	    <1->{Assumptions}
     {\linespread{1}\footnotesize\selectfont
        \begin{itemize}
            \item 市場上只有1和2兩個平台，沒有系統外部的干擾。平台號表示為i(i=1,2)
            \item 競爭主要發生在平台之間
        \end{itemize}}
    \end{exampleblock}
\end{frame}

%第十一頁
\begin{frame}{雙平台競爭模型}
\framesubtitle{Duopoly competition model of bilateral platform}
    \begin{block}
		<1->{Model}
            {\linespread{0.5}\footnotesize\selectfont
		\begin{align}
        \left\{
            \begin{aligned}
            \frac{dn_{1A}}{dt} & = & \mu_{1A}n_{1A}(1-\frac{n_{1A}}{N_{1A}}+r_{12}\frac{n_{2A}+n_{2B}}{N_{2A}+N_{2B}}+\theta_1\frac{n_{1B}}{N_{1B}})
            \\
            \frac{dn_{1B}}{dt} & = & \mu_{1B}n_{1B}(1-\frac{n_{1B}}{N_{1B}}+r_{12}\frac{n_{2A}+n_{2B}}{N_{2A}+N_{2B}}+\theta_1\frac{n_{1A}}{N_{1A}})
            \\
            \frac{dn_{2A}}{dt} & = & \mu_{2A}n_{2A}(1-\frac{n_{2A}}{N_{2A}}+r_{21}\frac{n_{1A}+n_{1B}}{N_{1A}+N_{1B}}+\theta_2\frac{n_{2B}}{N_{2B}})
            \\
            \frac{dn_{2B}}{dt} & = & \mu_{2B}n_{2B}(1-\frac{n_{2B}}{N_{2B}}+r_{21}\frac{n_{1A}+n_{1B}}{N_{1A}+N_{1B}}+\theta_2\frac{n_{2A}}{N_{2A}})
            \end{aligned}
        \right.
        \end{align}}        
    \end{block}	
\end{frame}

%第十二頁
\begin{frame}{雙平台競爭模型}
\framesubtitle{Duopoly competition model of bilateral platform}
    \begin{exampleblock}
    <1->{模型解釋}
     {\footnotesize\selectfont
        在這個模型中，我們可以用：
        \begin{itemize}
            \item $\frac{n_{1A}}{N_{1A}}$和$\frac{n_{1B}}{N_{1B}}$考慮該平台下容納用戶數量上限的對變化率的影響
            \item $r_{12}\frac{n_{2A}+n_{2B}}{N_{2A}+N_{2B}}$和$r_{21}\frac{n_{1A}+n_{1B}}{N_{1A}+N_{1B}}$考慮平台之間的交互作用
        \end{itemize}}
	\end{exampleblock}	
\end{frame}

%第十三頁
\begin{frame}{網絡外部性係數$\theta$}
        這個模型與Lotka–Volterra model不同之處在於多出的網絡外部性影響係數$\theta$。
        \begin{itemize}
            \item <1->要如何解釋$\theta$？
            {\footnotesize\selectfont
            \\平台兩側分別有商家及顧客，當其中一方數量增加，對另一方有正向影響，這時會出現跨網路外部性。這裡以$\frac{n_{1B}}{N_{1B}}$,$\frac{n_{1A}}{N_{1A}}$,$\frac{n_{2B}}{N_{2B}}$,$\frac{n_{2A}}{N_{2A}}$來將這種影響列入模型之中。又因為兩平台的跨網絡外部性影響大小不一定相同，再分別設定$\theta_1$、$\theta_2$來表示其大小。}
            \item <2->$\theta$的範圍
            {\footnotesize\selectfont
            \\$\theta_i$呈現的是平台雙邊用戶數的相關程度，且在此模型中，商家與顧客用戶數呈現正相關，因此設定0<$\theta_i$<1。}
        \end{itemize}
\end{frame}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%第十四頁
\begin{frame}{三平台競爭模型}
\framesubtitle{Three-oligarch platform competition model}
    雖然多個平台在同行業中往往競爭激烈，但我們想知道，政府或行業協會對第三方平台的積極支持，是否有利於打破現有壟斷，促進行業競爭。因此，我們將Lotka–Volterra模型從兩平台競爭模型擴展為三平台競爭模型。
    \begin{exampleblock}
	    <1->{Assumptions}
     {\linespread{1}\footnotesize\selectfont
        \begin{itemize}
            \item 三個平台在市場上競爭，沒有來自系統外部的干擾。 平台編號用i(i= 1, 2, 3)表示。 
            \item 競爭主要發生在平台之間
        \end{itemize}}
    \end{exampleblock}
\end{frame}

%第十五頁
\begin{frame}{三平台競爭模型}
\framesubtitle{Three-oligarch platform competition model}
    \begin{block}
		<1->{Model}
            {\linespread{0.5}\tiny\selectfont
		\begin{align}
        \left\{
            \begin{aligned}
            \frac{dn_{1A}}{dt} & = & \mu_{1A}n_{1A}(1-\frac{n_{1A}}{N_{1A}}+r_{12}\frac{n_{2A}+n_{2B}}{N_{2A}+N_{2B}}+r_{13}\frac{n_{3A}+n_{3B}}{N_{3A}+N_{3B}}+\theta_1\frac{n_{1B}}{N_{1B}})
            \\
            \frac{dn_{1B}}{dt} & = & \mu_{1B}n_{1B}(1-\frac{n_{1B}}{N_{1B}}+r_{12}\frac{n_{2A}+n_{2B}}{N_{2A}+N_{2B}}+r_{13}\frac{n_{3A}+n_{3B}}{N_{3A}+N_{3B}}+\theta_1\frac{n_{1A}}{N_{1A}})
            \\
            \frac{dn_{2A}}{dt} & = & \mu_{2A}n_{2A}(1-\frac{n_{2A}}{N_{2A}}+r_{21}\frac{n_{1A}+n_{1B}}{N_{1A}+N_{1B}}+r_{23}\frac{n_{3A}+n_{3B}}{N_{3A}+N_{3B}}+\theta_2\frac{n_{2B}}{N_{2B}})
            \\
            \frac{dn_{2B}}{dt} & = & \mu_{2B}n_{2B}(1-\frac{n_{2B}}{N_{2B}}+r_{21}\frac{n_{1A}+n_{1B}}{N_{1A}+N_{1B}}+r_{23}\frac{n_{3A}+n_{3B}}{N_{3A}+N_{3B}}+\theta_2\frac{n_{2A}}{N_{2A}})
            \\
            \frac{dn_{3A}}{dt} & = & \mu_{3A}n_{3A}(1-\frac{n_{3A}}{N_{3A}}+r_{31}\frac{n_{1A}+n_{1B}}{N_{1A}+N_{1B}}+r_{32}\frac{n_{2A}+n_{2B}}{N_{2A}+N_{2B}}+\theta_3\frac{n_{2B}}{N_{2B}})
            \\
            \frac{dn_{3B}}{dt} & = & \mu_{3B}n_{3B}(1-\frac{n_{3B}}{N_{3B}}+r_{31}\frac{n_{1A}+n_{1B}}{N_{1A}+N_{1B}}+r_{32}\frac{n_{2A}+n_{2B}}{N_{2A}+N_{2B}}+\theta_3\frac{n_{2B}}{N_{2B}})
            \end{aligned}
        \right.
        \end{align}}        
    \end{block}	
\end{frame}



