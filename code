		\item $N_{1B}=N_{2B}$=1000
            \item $\mu_{1A}=\mu_{2A}$=0.4
            \item $\mu_{1B}=\mu_{2B}$=0.2
	\end{itemize}}
    \end{block}
\end{frame}

%第十八頁
\begin{frame}{考慮內在增長率的影響}
