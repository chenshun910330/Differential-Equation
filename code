\section{實證分析}

%第二十三頁
\begin{frame}{實證分析}
\framesubtitle{競爭模型}
{\linespread{0.5}\footnotesize\selectfont
以"餓了嗎"、"美團"這兩家外賣平台公司雙方的用戶數量為對象，採用雙寡頭競爭模型探究這兩家公司的競爭關係。可以得到如下外賣平台企業的競爭模型：}
{\linespread{0.5}\tiny\selectfont
		\begin{align}
            \left\{
            \begin{aligned}
    \frac{dn_{1A}}{dt} & = 0.0095n_{1A}-(2.3774E-06)n^2_{1A}-(8.8169-06)n_{1A}(n_{2A}+n_{2B}) \\
    &\quad +(1.4509E-05)n_{1a}n_{1B}
    \\
    \\
    \frac{dn_{1B}}{dt} & = 0.006600n_{1B}-(1.4026E-05)n^2_{1B}-(6.1178-06)n_{1B}(n_{2A}+n_{2B}) \\
    &\quad +(1.1841E-06)n_{1a}n_{1B}
    \\
    \\
    \frac{dn_{2A}}{dt} & = 0.009672n_{2A}-(4.2257E-06)n^2_{2A}-(4.9526E-06)n_{2A}(n_{1A}+n_{1B}) \\
    &\quad +(2.9250E-06)n_{2a}n_{2B}
    \\
    \\
    \frac{dn_{2B}}{dt} & = 0.015880n_{2B}-(3.8900E-05)n^2_{2B}-(8.1310E-06)n_{2B}(n_{1A}+n_{1B}) \\
    &\quad +(8.5643E-07)n_{2a}n_{2B}
    \end{aligned}
    \right.
    \end{align} }      
\end{frame}

