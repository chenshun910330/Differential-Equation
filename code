%第三部分
\section{均衡結果分析}


%%第三部分第一小節
\subsection{雙平台均衡解}
%第十五頁
\begin{frame}{雙平台均衡解}
    \begin{block}
		<1->{第1種平衡解：其中一平台最終獨佔市場}
            {\linespread{0.5}\footnotesize\selectfont
		\begin{align}
            \left\{
            \begin{aligned}
            \quad & n_{1A} = 0
            \\
            \quad & n_{1B} = 0
            \\
            \quad & n_{2A} = \frac{n_{2A}}{1-\theta_2}
            \\
            \quad & n_{2B} = \frac{n_{2B}}{1-\theta_2}
    \end{aligned}
    \right.
    \end{align} }      
    \end{block}
\end{frame}

%第十六頁
\begin{frame}{雙平台均衡解}
    \begin{block}
		<1->{第2種平衡解：兩平台壟斷大多市場}
            {\linespread{0.5}\footnotesize\selectfont
		\begin{align}
            \left\{
            \begin{aligned}
            \quad & n_{1A} = \frac{N_{1A}(1+r_{12}-\theta_2)}{1+\theta_1(\theta_2-1)-\theta_2-r_{12}r_{21}}
            \\
            \quad & n_{1B} = \frac{N_{1B}(1+r_{12}-\theta_2)}{1+\theta_1(\theta_2-1)-\theta_2-r_{12}r_{21}}
            \\
            \quad & n_{2A} = \frac{N_{2A}(1+r_{21}-\theta_1)}{1+\theta_1(\theta_2-1)-\theta_2-r_{12}r_{21}}
            \\
            \quad & n_{2B} = \frac{N_{2B}(1+r_{12}-\theta_1)}{1+\theta_1(\theta_2-1)-\theta_2-r_{12}r_{21}}
    \end{aligned}
    \right.
    \end{align} }      
    \end{block}
\end{frame}


%%第三部分第二小節
\subsection{考慮內在增長率的影響}

%第十七頁
\begin{frame}{考慮內在增長率的影響}
\framesubtitle{當兩個平台無影響關係時 ($r_{12}=r_{21}$=0)}
    {\linespread{0.5}\footnotesize\selectfont
    作為模型中的重要參數，內在成長率的大小會影響到最終的均衡結果。文章共考慮三種狀態下內在成長率的影響：\textbf{平台間無影響、完全競爭、互利}。在兩平台間無互相影響關係時，先假設其他參數如下：}
    \begin{block}
    <1->{Assumption}            {\linespread{0.5}\footnotesize\selectfont
